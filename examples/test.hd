node<Test1>() : int * bool * int = 
    return (1,Switch(false, true),3);

node<Test2>() : int 
var x : int * bool * int; = 
    (x,y,z) := Test1 () + 2;
    return x + z;


node<START>() : unit 
var x : int * bool * int; = 
    (x,y,z) := Test1 () + 2;
    return x + z;