digraph finite_state_machine {
	fontname="Helvetica,Arial,sans-serif"
	node [fontname="Helvetica,Arial,sans-serif"]
	edge [fontname="Helvetica,Arial,sans-serif"]
	rankdir=LR;
	node [shape = doublecircle]; init 1;
	node [shape = circle];
	init -> init [label = "! off || ! on / ! on && ! light"];
	init -> 1 [label = "!off || ! on / ! off && on && light"];
	1 -> 1 [label = "! off || !on / !of /\ light"];
	1 -> init [label ="!off || ! on / off && !on && !light"];
}
