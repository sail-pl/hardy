input i : int;
output o : int;

var mem1 mem2 : int; 


//public spec 
guarantees G ( X X { o = i#2 })

//private spec 
guarantees G {mem2 = i}
guarantees X G {mem1 = prev i}
guarantees X G {mem1 = prev mem2}


START : {
    mem1 := 0;
    mem2 := 0;
} GOTO LOOP

LOOP :
{
    emit mem1 to o;
    mem1 := mem2;
    mem2 := i;
}
