input i;
output o;
var state o i ;

requires { forall x, x } 
ensures { True }

setup :
    state := 0;
loop :
    invariant { True }                                                                    
    if state > 5 then 
        o := true;
    else 
        x := 2; 
        state := state + 1 ;                                                                          
    end                                                                                          

