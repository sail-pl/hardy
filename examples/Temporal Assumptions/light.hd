input on off : bool;
output light : bool;
var curr_light : bool;


assumes G ({!{on}} || {!{off}})

guarantees {{on}}  R ({{on}} || {!{light}})
guarantees G ({{on}} -> {{off}} R ({{off}} || {{light}}))
guarantees G ({{off}} -> {{on}} R ({{on}} || {!{light}}))

setup : 
	ensures { !curr_light  }
	curr_light := false;

loop:
	invariant {curr_light = light}
	if on then 
		curr_light := true;
	else 
		if off then 
			curr_light := false;
		end
	end
	emit curr_light to light;

	
