output 
    accent : bool 
    beat : int
;

guarantees G {beat > 0}

guarantees G ( {beat = 1} <-> {accent})

guarantees G ( {beat = 1} -> X {beat = 2} && X X {beat = 3} && X X X {beat = 1} )


START : 
	ensures { beat = 1 && accent }
{
	emit 1 to beat;
    emit true to accent;
} GOTO LOOP

LOOP:
{
    if beat = 3 then 
	    emit 1 to beat;
        emit true to accent;
    else 
        emit beat+1 to beat;
        emit false to accent;
    end
}