input on off : bool;
output light : bool;
var x : bool;

relies on  G (! {on} || ! {off}).

guarantees {on}  R ({on} || ! {light}).
guarantees G ({on} -> {off} R ({off} || {light})).
guarantees G ({off} -> {on} R ({on} || ! {light})).

START : 
	ensures { light = false }
{
	emit false to light;
} GOTO LOOP


LOOP:
{
	if on then 
		emit true to light;
	else 
		if off then 
			emit false to light;
		end
	end
}	
