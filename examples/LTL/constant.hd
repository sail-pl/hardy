input i : int;
output o : int;
var x : int init : bool;

// public spec 
guarantees G {{o = first i}}

// private spec
guarantees G {{x = first i}}


setup :
    ensures { init = true }
    init := true;

loop :
    invariant {!init}
    if init then
        x := i;
        init := false;
    end
    emit x to o;