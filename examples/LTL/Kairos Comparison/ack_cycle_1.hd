// in kairos, can inspect output last value and do not have to produce output all the time ?
// no requirements on what to emit before the req

input 
  req : bool
;

output
  ack : bool
;

var 
  triggered : bool
;

//global
guarantees G ({{req}} => G {{ack}})


//local
guarantees G ({{req}} => G {{triggered}})

setup:
  ensures {!triggered}
  triggered := false;

loop:
    if req || triggered then
        triggered := true;
        emit true to ack;
    end