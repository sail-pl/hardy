use int.Int
use option.Option
use ref.Ref

type input_t = { input : int }

type output_t = { mutable output : option int }
  
type var_t = {mutable max : int}


let main () : () 
  diverges
  =
  let variables = { max = 0} in
    variables.max <- 0;
    assert {true};
    while (true) do
      let input_env = any input_t ensures {true} in
      let output_env = {output = None} in 
        if true  then variables.max <- input_env.input;
        output_env.output <- Some (variables.max);
        assert {match output_env.output with Some v -> v >= input_env.input | None -> false end}
    done
    (* (input.input > variables.max)*)
(* any / some *)
