use int.Int
use option.Option
use ref.Ref
use list.List
use list.Map
use list.Nth
use list.Length
use List.HdTl

(* Auxliary functions *)

predicate mem (x: 'a) (l: list 'a) = match l with
  | Nil      -> false
  | Cons y r -> x = y \/ mem x r
  end
      
let rec function for_all (p: 'a -> bool) (l:list 'a) : bool
  ensures { result <-> forall x. mem x l -> p x }
=
  match l with
  | Nil -> true
  | Cons x r -> p x && for_all p r
  end
  
  let rec function for_some (p: 'a -> bool) (l:list 'a) : bool
  ensures { result <-> exists x. mem x l /\ p x }
=
  match l with
  | Nil -> false
  | Cons x r -> p x || for_some p r
  end


(* Variables *)

type var_t = {
  mutable max : int
}

(* Environment *)

type env_t = {
  input_a : int;
  mutable output_b : option int
} 

(* History *)

type h_env_t = {
  h_input_a : int;
  h_output_b : int
}

type history_t = {
  mutable h_envs : list h_env_t
}
  
(* storage *)

let duplicate_env (env : env_t) : h_env_t 
  requires {env.output_b <> None} =
  match env.output_b with 
    | None -> absurd 
    | Some v -> {h_input_a = env.input_a; h_output_b = v} 
end

let store_history (h : history_t) (env : env_t) 
  requires { env.output_b <> None }
  ensures { length h.h_envs = length (old h.h_envs) + 1 }
  ensures {
    match h.h_envs with 
      | Nil -> false 
      | Cons h_env _ -> 
          h_env.h_input_a = env.input_a /\
          Some h_env.h_output_b = env.output_b
    end
  }
  ensures { 
    match h.h_envs with 
      | Nil -> false 
      | Cons _ l -> l = old h.h_envs 
    end
  }
  = h.h_envs <- Cons (duplicate_env env) h.h_envs

let main () : () 
  diverges
  =
  let history = {h_envs = Nil} in
  let variables = { max = 0} in
    variables.max <- 0;
    assert {true}; (* init ensures *)
    while (true) do
      invariant { (* past eventually *)
        variables.max > 0 ->
        for_some 
          (fun h_env -> h_env.h_input_a = variables.max) 
          history.h_envs
      }
      invariant { (* globally, I/O relation *)
        for_all 
          (fun h_env -> h_env.h_output_b >= h_env.h_input_a ) 
          history.h_envs
      }
      let env = any env_t ensures { (* Globally on inputs *) 
        result.input_a >= 0 /\
        result.output_b = None
      }
      in
        if env.input_a > variables.max 
        then variables.max <- env.input_a;
        env.output_b <- Some (variables.max);
        store_history history env
    done

  