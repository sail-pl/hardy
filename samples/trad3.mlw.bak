use int.Int
use option.Option
use ref.Ref
use list.List
use list.Map
use list.Nth
use list.Length


(* Variables *)

type var_t = {
  mutable max : int
}

(* Environment *)

type input_t = {
  input_a : int 
}

type output_t = { 
  mutable output_b : option int 
}

type env_t = {
  mutable env_input : input_t; 
  mutable env_output : output_t
} 

(* History *)

type ihist_t = {
  ihist_input_a : int
}

type ohist_t = {
  ohist_output_b : int
}

type history_t = {
  mutable h_envs : list (ihist_t, ohist_t)
}
  
(* storage *)

let duplicate_input (i : input_t) : ihist_t = 
  { ihist_input_a = i.input_a}

let duplicate_output (o : output_t) : ohist_t = 
  requires {o.output_b <> None}
  match o.output_b with 
    | Some v -> { ohist_output_b = v }
    | None -> absurd
  end

let duplicate_env (e : env_t) : (ihist_t, ohist_t) =
  requires {e.env_output.output_b <> None}
  (duplicate_input e.env_input, duplicate_output e.env_output)

let store_history (h : history_t) (e : env_t) : () 
  requires { e.env_output.output_b <> None }
  ensures {length h.h_envs = length (old h.h_envs) + 1}
  ensures {
    forall i o. nth 0 h.h_envs = Some (i, o) -> 
        i.ihist_input_a = e.env_input.input_a /\
        Some o.ohist_output_b = e.env_output.output_b
    }
  ensures {
    forall k. 1 <= k <= length h.
      h_envs - 1 -> nth k h.h_envs = nth (k -1) (old h.h_envs)
  } 
  = 
  let input = duplicate_input e.env_input in 
  let output = duplicate_output e.env_output in 
  h.h_envs <- Cons (input, output) h.h_envs

let main () : () 
  diverges
  =
  let history = {h_envs = Nil} in
  let variables = { max = 0} in
    variables.max <- 0;
    assert {true};
    while (true) do
      invariant {
        history.h_envs <> Nil -> 
        variables.max = 0 \/ 
        exists k, i, o.
          0 <= k < length history.h_envs /\
          nth k history.h_envs = Some (i,o) /\
            i.ihist_input_a = variables.max (* don't use variables ?*)
      }
      invariant {
        forall k: int, i o.
            0 <= k < length history.h_envs ->  
            nth k history.h_envs = Some (i,o) -> 
            o.ohist_output_b >= i.ihist_input
      }
      let env = {
        env_input = any input_t ensures {true}; 
        env_output = {output_b = None}
       } in
          if env.env_input.input_a > variables.max 
            then variables.max <- env.env_input.input_a;
          env.env_output.output_b <- Some (variables.max);
          store_history history env
    done

     (* assert {
        match env.env_output.output with 
          | Some v -> v >= env.env_input.input 
          | None -> false end
        }
        ;*)

